{% extends 'admin/forum/base.html.twig' %}

{% block title %}Forum Discussions{% endblock %}

{% block content %}
<!-- Page Header -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">Forum Discussions</h4>
            <div class="page-title-right">
                <a href="{{ path('admin_forum_discussion_new') }}" class="btn btn-primary">
                    <i class="material-icons-outlined">add</i> New Discussion
                </a>
            </div>
        </div>
    </div>
</div>

        <!-- Discussions List -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        {% if discussions %}
                            <div class="table-responsive">
                                <table class="table table-nowrap align-middle mb-0 forum-table">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Title</th>
                                            <th>Author</th>
                                            <th>Category</th>
                                            <th>Created</th>
                                            <th>Updated</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for discussion in discussions %}
                                            <tr>
                                                <td>{{ discussion.id }}</td>
                                                <td>
                                                    <a href="{{ path('forum_discussion', {'id': discussion.id}) }}" target="_blank">
                                                        <strong>{{ discussion.title|slice(0, 50) }}{{ discussion.title|length > 50 ? '...' : '' }}</strong>
                                                    </a>
                                                </td>
                                                <td>{{ discussion.author ? (discussion.author.name|default(discussion.author.email)) : 'Unknown' }}</td>
                                                <td>
                                                    {% if discussion.category %}
                                                        <span class="badge bg-info">{{ discussion.category.name }}</span>
                                                    {% else %}
                                                        <span class="badge bg-secondary">No category</span>
                                                    {% endif %}
                                                </td>
                                                <td>{{ discussion.createdAt|date('M d, Y H:i') }}</td>
                                                <td>
                                                    {% if discussion.updatedAt > discussion.createdAt %}
                                                        {{ discussion.updatedAt|date('M d, Y H:i') }}
                                                    {% else %}
                                                        -
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <a href="{{ path('admin_forum_discussion_edit', {'id': discussion.id}) }}" 
                                                           class="btn btn-sm btn-info" title="Edit">
                                                            <i class="material-icons-outlined">edit</i>
                                                        </a>
                                                        <form method="post" 
                                                              action="{{ path('admin_forum_discussion_delete', {'id': discussion.id}) }}" 
                                                              class="d-inline"
                                                              onsubmit="return confirm('Are you sure you want to delete this discussion and all its messages?')">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ discussion.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                                <i class="material-icons-outlined">delete</i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <i class="material-icons-outlined text-muted" style="font-size: 64px;">question_answer</i>
                                <h5 class="text-muted mt-3">No discussions found</h5>
                                <p class="text-muted">Users haven't created any discussions yet.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
