<script>
$(document).ready(function() {
    // Initialize MetisMenu
    $('#forum-sidenav').metisMenu();
    
    // Sidebar toggle
    $('.menu-toggle').click(function() {
        $('.forum-sidebar').toggleClass('sidebar-collapsed');
        $('.page-wrapper').toggleClass('sidebar-collapsed');
        $('.header').toggleClass('sidebar-collapsed');
    });
    
    // Sidebar close
    $('.sidebar-close').click(function() {
        $('.forum-sidebar').addClass('sidebar-collapsed');
        $('.page-wrapper').addClass('sidebar-collapsed');
        $('.header').addClass('sidebar-collapsed');
    });
    
    // Set initial state
    if ($(window).width() <= 768) {
        $('.forum-sidebar').addClass('sidebar-collapsed');
        $('.page-wrapper').addClass('sidebar-collapsed');
        $('.header').addClass('sidebar-collapsed');
    }
    
    // Handle window resize
    $(window).resize(function() {
        if ($(window).width() <= 768) {
            $('.forum-sidebar').addClass('sidebar-collapsed');
            $('.page-wrapper').addClass('sidebar-collapsed');
            $('.header').addClass('sidebar-collapsed');
        } else {
            $('.forum-sidebar').removeClass('sidebar-collapsed');
            $('.page-wrapper').removeClass('sidebar-collapsed');
            $('.header').removeClass('sidebar-collapsed');
        }
    });
    
    // Remove loader
    $('.loader-wrap').fadeOut(500);
});
</script>

