{% extends 'admin/forum/base.html.twig' %}

{% block title %}Forum Categories{% endblock %}

{% block content %}
<!-- Page Header -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">Forum Categories</h4>
            <div class="page-title-right">
                <a href="{{ path('admin_forum_category_new') }}" class="btn btn-primary">
                    <i class="material-icons-outlined">add</i> New Category
                </a>
            </div>
        </div>
    </div>
</div>

        <!-- Categories List -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        {% if categories %}
                            <div class="table-responsive">
                                <table class="table table-nowrap align-middle mb-0 forum-table">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Name</th>
                                            <th>Description</th>
                                            <th>Created</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for category in categories %}
                                            <tr>
                                                <td>{{ category.id }}</td>
                                                <td>
                                                    <strong>{{ category.name }}</strong>
                                                </td>
                                                <td>
                                                    <span class="text-muted">
                                                        {{ category.description|slice(0, 100) }}{{ category.description|length > 100 ? '...' : '' }}
                                                    </span>
                                                </td>
                                                <td>{{ category.createdAt|date('M d, Y H:i') }}</td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        <a href="{{ path('admin_forum_category_edit', {'id': category.id}) }}" 
                                                           class="btn btn-sm btn-info" title="Edit">
                                                            <i class="material-icons-outlined">edit</i>
                                                        </a>
                                                        <form method="post" 
                                                              action="{{ path('admin_forum_category_delete', {'id': category.id}) }}" 
                                                              class="d-inline"
                                                              onsubmit="return confirm('Are you sure you want to delete this category and all its discussions?')">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                                <i class="material-icons-outlined">delete</i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <i class="material-icons-outlined text-muted" style="font-size: 64px;">category</i>
                                <h5 class="text-muted mt-3">No categories found</h5>
                                <p class="text-muted">Create your first forum category to get started.</p>
                                <a href="{{ path('admin_forum_category_new') }}" class="btn btn-primary">
                                    <i class="material-icons-outlined">add</i> Create First Category
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
