{% extends 'admin/forum/base.html.twig' %}

{% block title %}Forum Messages{% endblock %}

{% block content %}
<!-- Page Header -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">Forum Messages</h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript: void(0);">Forum</a></li>
                    <li class="breadcrumb-item active">Messages</li>
                </ol>
            </div>
        </div>
    </div>
</div>

        <!-- Messages List -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        {% if messages %}
                            <div class="table-responsive">
                                <table class="table table-nowrap align-middle mb-0 forum-table">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Author</th>
                                            <th>Content</th>
                                            <th>Discussion</th>
                                            <th>Votes</th>
                                            <th>Created</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for message in messages %}
                                            <tr>
                                                <td>{{ message.id }}</td>
                                                <td>{{ message.author ? (message.author.name|default(message.author.email)) : 'Unknown' }}</td>
                                                <td>
                                                    {{ message.content|slice(0, 80) }}{{ message.content|length > 80 ? '...' : '' }}
                                                </td>
                                                <td>
                                                    {% if message.discussion %}
                                                        <a href="{{ path('forum_discussion', {'id': message.discussion.id}) }}" target="_blank">
                                                            {{ message.discussion.title|slice(0, 30) }}{{ message.discussion.title|length > 30 ? '...' : '' }}
                                                        </a>
                                                    {% else %}
                                                        <span class="text-muted">No discussion</span>
                                                    {% endif %}
                                                </td>
                                                <td>
                                                    <span class="badge bg-success me-1">↑{{ message.upvotes }}</span>
                                                    <span class="badge bg-danger">↓{{ message.downvotes }}</span>
                                                </td>
                                                <td>{{ message.createdAt|date('M d, Y H:i') }}</td>
                                                <td>
                                                    <div class="d-flex gap-2">
                                                        {% if message.discussion %}
                                                            <a href="{{ path('forum_discussion', {'id': message.discussion.id}) }}" 
                                                               target="_blank"
                                                               class="btn btn-sm btn-info" title="View in Discussion">
                                                                <i class="material-icons-outlined">visibility</i>
                                                            </a>
                                                        {% endif %}
                                                        <form method="post" 
                                                              action="{{ path('admin_forum_message_delete', {'id': message.id}) }}" 
                                                              class="d-inline"
                                                              onsubmit="return confirm('Are you sure you want to delete this message?')">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ message.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                                <i class="material-icons-outlined">delete</i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <i class="material-icons-outlined text-muted" style="font-size: 64px;">comment</i>
                                <h5 class="text-muted mt-3">No messages found</h5>
                                <p class="text-muted">Users haven't posted any messages yet.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
