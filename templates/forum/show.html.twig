    border: 1px solid rgba(255,255,255,0.15) !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
}

.original-post::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    border-radius: 15px 15px 0 0;
}

.post-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 20px !important;
}

.post-meta {
    font-size: 14px;
    opacity: 0.8;
}

.post-meta span {
    margin-right: 15px;
}

.messages-section {
    margin-top: 50px;
}

.messages-section h3 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 30px !important;
    padding-bottom: 15px;
    border-bottom: 2px solid rgba(255,255,255,0.1);
}

.message-item {
    position: relative;
